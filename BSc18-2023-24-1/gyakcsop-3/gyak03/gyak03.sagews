# b megoldás

# N = 3
# pl. 4! = 1*2*3*4
#          4
#          3
#          2

# [4! + 2, 4! + 3, 4! + 4]


def Compound_List(N):
    return [ factorial(N + 1) + 2 .. factorial(N+1) + N + 1 ]

Compound_List(2)
Compound_List(10)
Compound_List(100)

