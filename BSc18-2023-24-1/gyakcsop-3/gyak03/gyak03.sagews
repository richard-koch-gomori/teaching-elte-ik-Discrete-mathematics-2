# gyak03

# R reláció, A halmazon
# tranzitív: minden a, b, c eleme A-ra: aRb és bRc akkor aRc



def Is_Transitive(A, R):
    for a in A:
        for b in A:
            for c in A:
                if (a, b) in R and (b, c) in R and (a, c) not in R:
                    return False

    return True

Is_Transitive({1, 2, 3}, [(1,1), (1,2), (1,3), (2,1), (2,2), (2,3), (3,1), (3,2), (3,3)])
Is_Transitive({1, 2, 3, 4}, [(1, 2), (2, 3), (1, 4), (2, 2)])


