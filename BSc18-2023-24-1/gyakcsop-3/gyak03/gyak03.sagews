def  Compound_List(N):
    result = []
    counter = 4
    while len(result) < N:
        if is_prime(counter):
            result = []
        else:
            result.append(counter)
        counter += 1
    return result

Compound_List(3)
Compound_List(4)
Compound_List(10)
Compound_List(100)

