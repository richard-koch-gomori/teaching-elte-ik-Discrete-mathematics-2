# fel2

def Goldbach(n):
    if n % 2 != 0 or n <= 2:
        raise ValueError("invalid n")

    counter = 2
    while counter < n:
        if is_prime(counter):
            other = n - counter
            if is_prime(other):
                return [counter, other]
        counter += 1

Goldbach(4)
Goldbach(16)
Goldbach(160)

