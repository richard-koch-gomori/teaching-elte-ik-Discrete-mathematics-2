def RSA_encrypt(plaintext, pub_key):
    m = Convert_String_to_Num256(plaintext)
    #print(m)
    #return m^(pub_key[1]) % pub_key[0] # nagy inputra sokáig tart a hatványozást a^b mod c kiszámolni
    return power_mod(m, pub_key[1], pub_key[0])

